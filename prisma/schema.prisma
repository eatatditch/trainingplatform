generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum FileType {
  PDF
  DOCUMENT
  VIDEO
  IMAGE
  CHECKLIST
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  authId    String?  @unique // Supabase auth.users.id
  email     String   @unique
  firstName String
  lastName  String
  role      UserRole @default(EMPLOYEE)
  location  String?
  phone     String?
  hireDate  DateTime?
  isActive  Boolean  @default(true)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizAttempts  QuizAttempt[]
  trainingPaths UserTrainingPath[]
  assignments   ModuleAssignment[]
  completions   ModuleCompletion[]
  announcements Announcement[]       @relation("AnnouncementAuthor")
  assignedBy    ModuleAssignment[]   @relation("AssignedByUser")

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([location])
}

// ─── Section ─────────────────────────────────────────────────────────────────

model Section {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String   @unique
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules       Module[]
  searchIndexes SearchIndex[]

  @@index([slug])
  @@index([sortOrder])
}

// ─── Module ──────────────────────────────────────────────────────────────────

model Module {
  id               String   @id @default(cuid())
  sectionId        String
  title            String
  description      String?
  slug             String   @unique
  content          String?  @db.Text
  estimatedMinutes Int?
  isRequired       Boolean  @default(false)
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  tags             String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  section       Section              @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  assets        ModuleAsset[]
  quiz          Quiz?
  pathModules   TrainingPathModule[]
  assignments   ModuleAssignment[]
  completions   ModuleCompletion[]
  searchIndexes SearchIndex[]

  @@index([sectionId])
  @@index([slug])
  @@index([sortOrder])
  @@index([isActive])
}

// ─── ModuleAsset ─────────────────────────────────────────────────────────────

model ModuleAsset {
  id          String   @id @default(cuid())
  moduleId    String
  fileName    String
  fileUrl     String
  fileType    FileType
  fileSize    Int?
  isPrintable Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([fileType])
}

// ─── Quiz ────────────────────────────────────────────────────────────────────

model Quiz {
  id           String   @id @default(cuid())
  moduleId     String   @unique
  title        String
  description  String?
  passingScore Int      @default(70)
  retryLimit   Int      @default(0)
  isRequired   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  module    Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([moduleId])
}

// ─── QuizQuestion ────────────────────────────────────────────────────────────

model QuizQuestion {
  id            String       @id @default(cuid())
  quizId        String
  questionText  String
  questionType  QuestionType
  options       Json?
  correctAnswer String
  explanation   String?
  sortOrder     Int          @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([sortOrder])
}

// ─── QuizAttempt ─────────────────────────────────────────────────────────────

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  userId      String
  score       Int
  passed      Boolean
  answers     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@index([userId, quizId])
}

// ─── TrainingPath ────────────────────────────────────────────────────────────

model TrainingPath {
  id          String    @id @default(cuid())
  title       String
  description String?
  targetRole  String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  modules     TrainingPathModule[]
  assignments UserTrainingPath[]

  @@index([isActive])
}

// ─── TrainingPathModule ──────────────────────────────────────────────────────

model TrainingPathModule {
  id             String  @id @default(cuid())
  trainingPathId String
  moduleId       String
  sortOrder      Int     @default(0)
  isRequired     Boolean @default(true)

  trainingPath TrainingPath @relation(fields: [trainingPathId], references: [id], onDelete: Cascade)
  module       Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([trainingPathId, moduleId])
  @@index([trainingPathId])
  @@index([moduleId])
}

// ─── UserTrainingPath ────────────────────────────────────────────────────────

model UserTrainingPath {
  id             String    @id @default(cuid())
  userId         String
  trainingPathId String
  assignedAt     DateTime  @default(now())
  dueDate        DateTime?
  completedAt    DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPath TrainingPath @relation(fields: [trainingPathId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingPathId])
  @@index([userId])
  @@index([trainingPathId])
  @@index([dueDate])
}

// ─── ModuleAssignment ────────────────────────────────────────────────────────

model ModuleAssignment {
  id            String           @id @default(cuid())
  userId        String
  moduleId      String
  assignedById  String?
  isRequired    Boolean          @default(true)
  dueDate       DateTime?
  assignedAt    DateTime         @default(now())
  completedAt   DateTime?
  status        AssignmentStatus @default(NOT_STARTED)

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module       Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  assignedByUser User?  @relation("AssignedByUser", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@index([status])
  @@index([dueDate])
}

// ─── ModuleCompletion ────────────────────────────────────────────────────────

model ModuleCompletion {
  id          String   @id @default(cuid())
  userId      String
  moduleId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
}

// ─── Announcement ────────────────────────────────────────────────────────────

model Announcement {
  id          String               @id @default(cuid())
  title       String
  content     String               @db.Text
  priority    AnnouncementPriority @default(NORMAL)
  isActive    Boolean              @default(true)
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  createdByUser User @relation("AnnouncementAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([priority])
  @@index([expiresAt])
  @@index([createdById])
}

// ─── SearchIndex ─────────────────────────────────────────────────────────────

model SearchIndex {
  id          String  @id @default(cuid())
  moduleId    String?
  sectionId   String?
  contentType String
  title       String
  content     String  @db.Text
  tags        String[]

  module  Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  section Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([sectionId])
  @@index([contentType])
}
